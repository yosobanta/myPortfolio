# ═══════════════════════════════════════════
# ENVIRONMENT VARIABLES TEMPLATE
# ═══════════════════════════════════════════
# Copy this file to .env and fill in your actual values
# DO NOT COMMIT .env file - it's already in .gitignore

# Personal Contact Email (used in HeroSection)
VITE_USER_EMAIL=your.email@example.com

# Form Submission Endpoint (Formspree integration)
# Get your unique endpoint from https://formspree.io
VITE_FORMSPREE_ENDPOINT=https://formspree.io/f/YOUR_FORMSPREE_ID

# Certificate Verification Links (Google Drive - Private Files)
# These are private document links - replace with your own
VITE_CERT_DRIVE_CLOUD_COMPUTING=https://drive.google.com/file/d/YOUR_FILE_ID/view?usp=sharing
VITE_CERT_DRIVE_COMPUTATION_THEORY=https://drive.google.com/file/d/YOUR_FILE_ID/view?usp=drive_link
VITE_CERT_DRIVE_MERN_GENAI=https://drive.google.com/file/d/YOUR_FILE_ID/view?usp=drive_link
VITE_CERT_DRIVE_WEB_DESIGN=https://drive.google.com/file/d/YOUR_FILE_ID/view?usp=sharing
